{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "model": "ollama/gemma4:31b-mlx",
  "small_model": "ollama/gemma4:31b-mlx",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:31b-mlx": {
          "name": "Gemma 4 31B (local)"
        }
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "rm -rf *": "deny"
    }
  },
  "instructions": [
    "AGENTS.md",
    "docs/STYLE.md"
  ]
}
